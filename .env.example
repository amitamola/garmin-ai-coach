# Copy this file to `.env` and fill in your own values, OR set these as real
# environment variables. `.env` is git-ignored. Nothing here is committed.
#
# The bot reads most of these directly from the environment. On Windows/PowerShell
# use  $env:NAME = "value"  ; on Linux/Mac use  export NAME=value  (or a tool like
# python-dotenv / direnv). The run scripts in ./scripts set the encoding vars for you.

# ---- Telegram (required) ----
# Token from @BotFather (looks like 123456789:AA...). You can instead drop it in
# state/telegram_token.txt.
AGBOT_TELEGRAM_TOKEN=
# Your numeric chat id (message the bot, then open
# https://api.telegram.org/bot<TOKEN>/getUpdates and read chat.id). You can instead
# drop it in state/telegram_chat_id.txt.
AGBOT_OWNER_CHAT_ID=

# ---- Garmin Connect (required for the first login) ----
# After the first successful login, OAuth tokens are cached (see GARMINTOKENS) and
# you can remove these again.
EMAIL=
PASSWORD=
# Where Garmin OAuth tokens are cached. Defaults to ~/.garminconnect.
# GARMINTOKENS=~/.garminconnect

# ---- Model / agent backend ----
# Which backend generates replies. "copilot" (default) uses the GitHub Copilot CLI.
# See run_llm() in telegram_bridge.py to enable openai / anthropic / ollama.
AGBOT_LLM=copilot
# Only needed for the default "copilot" backend if `copilot` isn't already on PATH:
# COPILOT_EXE=copilot
# COPILOT_HOME=

# ---- Optional personalization ----
# Your first name, used only so the coach can greet you. All real personalization
# lives in profile.md.
AGBOT_USER_NAME=
